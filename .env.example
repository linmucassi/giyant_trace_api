# ================================
# GiyantTrace Environment Variables
# ================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/giyant_trace

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend URLs
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
API_URL=http://localhost:3001

# File Storage (S3-compatible)
STORAGE_PROVIDER=local
AWS_REGION=af-south-1
AWS_BUCKET=giyant-trace
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@giyanttrace.com
EMAIL_FROM_NAME=GiyantTrace

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Webhooks
WEBHOOK_SECRET=your-webhook-secret

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Encryption (for magic link tokens)
ENCRYPTION_KEY=your-32-char-encryption-key-here!
